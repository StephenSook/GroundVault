# Copy this file to `.env` and fill values. NEVER commit `.env`.
# `.gitignore` already excludes `.env` and `.env.*` (with explicit allow for `.env.example`).

# --- Arbitrum Sepolia (chain 421614) ---
# Default fallback RPC works without auth, but expect rate limits.
# Replace with Alchemy / Infura / QuickNode endpoint for production work.
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Hex private key (NO 0x prefix) of the deployer wallet.
# This is the same wallet used for the iExec Hello World registration:
#   0x9Fba564bC5319101Ee373a09676f1e4857676f15
PRIVATE_KEY=

# Arbiscan API key for contract verification.
# Register at: https://arbiscan.io/myapikey
ARBISCAN_API_KEY=

# --- Off-chain data sources (Phase 5) ---

# HUD CHAS API (Fulton County GA cost-burden data)
# Signup: https://www.huduser.gov/portal/dataset/chas-api.html
HUD_API_TOKEN=

# ChainGPT Web3 LLM + Smart Contract Auditor
# Signup + free credits: ChainGPT Discord
CHAINGPT_API_KEY=

# FRED (Treasury yields, used for impact memo benchmarks)
# Signup: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
