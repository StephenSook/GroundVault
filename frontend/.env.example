# Copy to `frontend/.env` (gitignored). Vite reads VITE_-prefixed
# variables at build/dev time. Each is optional — fallbacks render
# without keys, just with reduced fidelity.

# HUD CHAS API (Comprehensive Housing Affordability Strategy).
# Bearer token from https://www.huduser.gov/portal/dataset/chas-api.html
VITE_HUD_API_TOKEN=

# FRED (Federal Reserve Economic Data) API key.
# Free key from https://fredaccount.stlouisfed.org/apikeys
VITE_FRED_API_KEY=

# ChainGPT API key — LOCAL DEV ONLY.
# Set this for `vite dev`, where the Vercel Edge proxy at
# /api/chaingpt is not served. In production / Vercel preview, set
# CHAINGPT_API_KEY (no VITE_ prefix) on the deployment instead — the
# proxy keeps the key server-side. Never set both at once on a
# production build; the VITE_-prefixed value is bundled into the
# client.
# https://app.chaingpt.org -> dashboard -> API keys
VITE_CHAINGPT_API_KEY=

# Demo bypasses. When set to "1", the frontend honors three URL
# query-string overrides used to demo design states without a real
# wallet:
#   ?status=verified|pending|unverified  (skip IdentityRegistry read)
#   ?wallet=mock                         (simulate connected wallet)
#   ?role=memo                           (show MEMO_ROLE regenerate UI)
# Default off so production builds without the flag cannot be put
# into a demo-mock state by URL alone. Set this to 1 in local dev
# and (optionally) on the Vercel preview that judges click through.
VITE_ALLOW_DEMO_BYPASSES=
